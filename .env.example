# =============================================================================
# Pet-Pag — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite o .env.local no git
# =============================================================================

# --- Banco de Dados (NeonDB) --------------------------------------------------
# Dashboard: https://console.neon.tech
# Copie a "Connection string" do seu projeto Neon
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/petpag?sslmode=require"

# --- Autenticação (NextAuth v5) -----------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# --- Email (Resend) -----------------------------------------------------------
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@petpag.com.br"
RESEND_FROM_NAME="Pet-Pag"

# --- Upload de Imagens (UploadThing) -----------------------------------------
# Dashboard: https://uploadthing.com/dashboard
UPLOADTHING_SECRET="sk_live_xxxxxxxxxxxx"
UPLOADTHING_APP_ID="xxxxxxxxxxxx"

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Pet-Pag"

# --- Google OAuth (opcional, para login social) -------------------------------
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""
